# Doit faire au moins 32 caractères. Sert à signer les access tokens (15 min) et
# les jetons courts (présentation, 2FA pending). Les refresh tokens sont opaques et
# stockés hachés en base — pas besoin d'un secret séparé.
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
DATABASE_URL="postgresql://user:password@host/teac?sslmode=require"
PORT=3001
# Origine autorisée pour CORS — doit être l'ORIGINE SEULE (schéma + hôte, sans chemin),
# sinon le navigateur rejette les réponses. Ex. en prod : https://ilyas8888.github.io
CLIENT_URL="http://localhost:5173"
# URL complète du frontend, chemin de base INCLUS, pour les liens dans les emails
# (vérification, réinitialisation). Sur GitHub Pages l'app est servie sous /teac :
# APP_URL="https://ilyas8888.github.io/teac". Par défaut = CLIENT_URL (dev local).
APP_URL="http://localhost:5173"
HF_TOKEN="hf_your_huggingface_token"
HF_MODEL="mistralai/Mistral-7B-Instruct-v0.2"
# SMTP : requis pour l'envoi réel des emails (vérification, réinitialisation).
# Sans ces variables, les emails sont seulement loggés côté serveur.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Teac <no-reply@teac.app>"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_PRESET="teac-preset"
